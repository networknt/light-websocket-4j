{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "type" : "object",
  "required" : [ "enabled", "defaultProtocol", "defaultEnvTag", "idleTimeoutMs", "pathPrefixService" ],
  "properties" : {
    "enabled" : {
      "type" : "boolean",
      "description" : "Enable WebSocket Router Handler",
      "default" : true
    },
    "defaultProtocol" : {
      "type" : "string",
      "description" : "Default downstream protocol when not specified in the request. It can be http or https.",
      "default" : "http"
    },
    "defaultEnvTag" : {
      "type" : "string",
      "description" : "Default downstream envTag when not specified in the request. Like dev/sit/stg/prd etc."
    },
    "idleTimeoutMs" : {
      "type" : "integer",
      "description" : "Idle timeout in milliseconds for WebSocket connections.",
      "default" : 3600000,
      "minimum" : 1
    },
    "pathPrefixService" : {
      "type" : "object",
      "description" : "Map of path prefix to downstream serviceId attributes for routing when service_id header is missing.",
      "additionalProperties" : {
        "oneOf" : [ {
          "type" : "string"
        }, {
          "type" : "object",
          "properties" : {
            "protocol" : {
              "type" : "string"
            },
            "serviceId" : {
              "type" : "string"
            },
            "envTag" : {
              "type" : "string"
            }
          },
          "required" : [ "serviceId" ]
        } ]
      }
    }
  }
}
